     12  0000 ????						; Constants
     13  0000 ????						;------------------------------------------------
     14  0000 ????	       00 00	   BLACK      =	#$00
     15  0000 ????	       00 07	   SCORE_HEIGHT =	#7
     16  0000 ????						;------------------------------------------------
     17  0000 ????						; RAM
     18  0000 ????						;------------------------------------------------
     19 U0093 ????				      SEG.U	variables
