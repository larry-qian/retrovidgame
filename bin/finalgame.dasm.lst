     13  0000 ????	       00 00	   BLACK      =	#$00
     14  0000 ????	       00 07	   SCORE_HEIGHT =	#7
     15  0000 ????	       00 06	   BIKE_HEIGHT =	#6
     16  0000 ????	       00 9e	   PLAY_HEIGHT =	#158
