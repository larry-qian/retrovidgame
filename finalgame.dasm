    .byte   %01111100

LetterP
    .byte   %01100000
    .byte   %01100000
    .byte   %01100000
    .byte   %01111100
    .byte   %01100110
    .byte   %01100110
    .byte   %01111100
    .byte   %00000000

LetterS
    .byte   %01111100
    .byte   %01100110
    .byte   %00000110
    .byte   %00111100
    .byte   %01100000
    .byte   %01100110
    .byte   %01111100
    .byte   %00000000

LetterF
    .byte   %01100000
    .byte   %01100000
    .byte   %01100000
    .byte   %01111100
    .byte   %01100000
    .byte   %01100000
    .byte   %01111110
    .byte   %00000000

LetterI
    .byte   %00111100
    .byte   %00011000
    .byte   %00011000
    .byte   %00011000
    .byte   %00011000
    .byte   %00011000
    .byte   %00111100
    .byte   %00000000

LetterL
    .byte   %01111110
    .byte   %01100000
    .byte   %01100000
    .byte   %01100000
    .byte   %01100000
    .byte   %01100000
    .byte   %01100000
    .byte   %00000000

    align 256
PlayerGfx
    .byte   %00000000
    .byte   %01100110  
    .byte   %11111111  
    .byte   %01111110  
    .byte   %00111100  
    .byte   %00111100  
    .byte   %00011000  
    .byte   %00000000
	align 256
MonsterGfx
    .byte   %11111111, %11111111, %11111111, %11111111
    .byte   %11111110, %11111110, %11111110, %11111110
    .byte   %11111100, %11111100, %11111100, %11111100
    .byte   %11111000, %11111000, %11111000, %11111000
    .byte   %11110000, %11110000, %11110000, %11110000
    .byte   %11111000, %11111000, %11111000, %11111000
    .byte   %11111100, %11111100, %11111100, %11111100
    .byte   %11111110, %11111110, %11111110, %11111110

    .byte   %11111111, %11111111, %11111111, %11111111
    .byte   %11111110, %11111110, %11111110, %11111110
    .byte   %11111100, %11111100, %11111100, %11111100
    .byte   %11111000, %11111000, %11111000, %11111000
    .byte   %11110000, %11110000, %11110000, %11110000
    .byte   %11111000, %11111000, %11111000, %11111000
    .byte   %11111100, %11111100, %11111100, %11111100
    .byte   %11111110, %11111110, %11111110, %11111110

    .byte   %11111111, %11111111, %11111111, %11111111
    .byte   %11111110, %11111110, %11111110, %11111110
    .byte   %11111100, %11111100, %11111100, %11111100
    .byte   %11111000, %11111000, %11111000, %11111000
    .byte   %11110000, %11110000, %11110000, %11110000
    .byte   %11111000, %11111000, %11111000, %11111000
    .byte   %11111100, %11111100, %11111100, %11111100
    .byte   %11111110, %11111110, %11111110, %11111110

    .byte   %11111111, %11111111, %11111111, %11111111
    .byte   %11111110, %11111110, %11111110, %11111110
    .byte   %11111100, %11111100, %11111100, %11111100
    .byte   %11111000, %11111000, %11111000, %11111000
    .byte   %11110000, %11110000, %11110000, %11110000
    .byte   %11111000, %11111000, %11111000, %11111000
    .byte   %11111100, %11111100, %11111100, %11111100
    .byte   %11111110, %11111110, %11111110, %11111110

    ; --- Added 5th block to complete the 160 scanline requirement ---
    .byte   %11111111, %11111111, %11111111, %11111111
    .byte   %11111110, %11111110, %11111110, %11111110
    .byte   %11111100, %11111100, %11111100, %11111100
    .byte   %11111000, %11111000, %11111000, %11111000
    .byte   %11110000, %11110000, %11110000, %11110000
    .byte   %11111000, %11111000, %11111000, %11111000
    .byte   %11111100, %11111100, %11111100, %11111100
    .byte   %11111110, %11111110, %11111110, %11111110

collectSpawnTable
    .byte   100, 30
    .byte   130, 50
    .byte   90,  80
    .byte   140, 100
    .byte   110, 120
    .byte   125, 140

    echo [*-$F000]d, " ROM bytes used"
    ORG    $FFFA
    .word  Start
    .word  Start
    .word  Start
    
    END