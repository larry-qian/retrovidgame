    .byte   %00001100
five
    .byte   %01111100
    .byte   %01000110
    .byte   %00000110
    .byte   %00000110
    .byte   %01111100
    .byte   %01100000
    .byte   %01100000
    .byte   %01111110
six
    .byte   %00111100
    .byte   %01100110
    .byte   %01100110
    .byte   %01100110
    .byte   %01111100
    .byte   %01100000
    .byte   %01100010
    .byte   %00111100
seven
    .byte   %00011000
    .byte   %00011000
    .byte   %00011000
    .byte   %00011000
    .byte   %00001100
    .byte   %00000110
    .byte   %01000010
    .byte   %01111110
eight
    .byte   %00111100
    .byte   %01100110
    .byte   %01100110
    .byte   %00111100
    .byte   %00111100
    .byte   %01100110
    .byte   %01100110
    .byte   %00111100
nine
    .byte   %00111100
    .byte   %01000110
    .byte   %00000110
    .byte   %00111110
    .byte   %01100110
    .byte   %01100110
    .byte   %01100110
    .byte   %00111100
blank
    .byte   %00000000
    .byte   %00000000
    .byte   %00000000
    .byte   %00000000
    .byte   %00000000
    .byte   %00000000
    .byte   %00000000
    .byte   %00000000

