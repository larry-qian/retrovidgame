; Text Graphic Data (bottom-to-top layout)
; ===================
LetterG
    .byte   %00111100
    .byte   %01100110
    .byte   %01101110
    .byte   %01100000
    .byte   %01100000
    .byte   %01100110
    .byte   %01100110
    .byte   %00111100

LetterA
    .byte   %01100110
    .byte   %01100110
    .byte   %01111110
    .byte   %01100110
    .byte   %00100100
    .byte   %00100100
